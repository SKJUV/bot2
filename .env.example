# ================================
# Configuration du Bot WhatsApp
# ================================
# Copiez ce fichier en .env et remplissez vos valeurs
# cp .env.example .env

# Port du serveur web (health check)
PORT=3000

# Clé API Google Gemini (pour la commande IA)
# Obtenez-la sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Numéros des propriétaires du bot (séparés par des virgules, format international sans +)
# Exemple : 33612345678,237699112233
OWNER_NUMBERS=

# Numéros bannis (séparés par des virgules, laisser vide par défaut)
BANNED_NUMBERS=

# Nom du bot (affiché dans les messages)
BOT_NAME=WhatsBot

# Nom du créateur (affiché dans about, help, info)
CREATOR_NAME=Developer

# Liens du créateur (optionnels, pour la commande about)
GITHUB_LINK=https://github.com
LINKEDIN_LINK=

# Préfixe des commandes
PREFIX=.

# Mode illimité (true = pas de limite de commandes, false = limite activée)
UNLIMITED_MODE=true

# Limite de commandes gratuites par utilisateur (si UNLIMITED_MODE=false)
COMMAND_LIMIT=3

# Cooldown anti-spam entre les commandes (en millisecondes, défaut: 3000 = 3s)
COOLDOWN_MS=3000

# ================================
# Mode Assistant Personnel
# ================================

# Mode assistant (true = réponses en IB uniquement, seul le owner commande)
# Mode public  (false = tout le monde peut utiliser le bot)
ASSISTANT_MODE=true

# Détection automatique des vues uniques (true = notifie le owner en IB)
AUTO_VIEWONCE=true

# Taille du buffer de messages par groupe pour .resume (défaut: 200)
GROUP_BUFFER_SIZE=200

# Traiter les anciens messages au démarrage ? (false = ignorer, recommandé)
PROCESS_OLD_MESSAGES=false

# Synchroniser l'historique complet WhatsApp au démarrage ? (false = recommandé)
# true = télécharge tout l'historique (lent, beaucoup de données)
SYNC_FULL_HISTORY=false

# Message de bienvenue du groupe (optionnel, utilisé par la commande add)
# GROUP_WELCOME_MESSAGE=Bienvenue ! Lisez les règles du groupe.

# Prompt système personnalisé pour l'IA (optionnel)
# AI_SYSTEM_PROMPT=Tu es un assistant IA utile et amical.

# Cookies YouTube (base64) — Résout le blocage "Sign in to confirm you're not a bot"
# sur les hébergeurs cloud (Render, Railway, etc.)
# Voir README pour les instructions d'export
# YT_COOKIES_BASE64=

# Dossier temporaire pour les téléchargements YouTube (play, deo)
# Par défaut : /tmp (fonctionne en local et sur la plupart des hébergeurs)
# TEMP_DIR=/tmp

# ================================
# Mode SaaS / Multi-instance
# ================================

# Dossier d'authentification Baileys (important pour isolation par utilisateur)
# Exemple SaaS: /usr/src/app/auth_info/user_1234
# AUTH_DIR=/usr/src/app/auth_info

# Active le jumelage par code (désactive l'affichage QR dans les logs)
# PAIRING_MODE=true

# Numéro pour générer le pairing code (chiffres uniquement, sans + ni espaces)
# Exemple: 2250102030405
# PHONE_NUMBER=

# Délai avant nouvelle tentative de pairing si le code n'a pas abouti (ms)
# PAIRING_RETRY_MS=120000

# Nombre maximum de codes de jumelage à générer avant d'arrêter les retries
# PAIRING_MAX_ATTEMPTS=5

# Webhook de gestion (plateforme SaaS) pour recevoir les événements du bot
# Events envoyés: status, qr, pairing_code, pairing_error
# WEBHOOK_URL=https://api.example.com/webhooks/whatsapp

# Identifiant de l'instance, renvoyé dans les payloads webhook
# INSTANCE_ID=bot-user-1234
