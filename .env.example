# ================================
# Configuration du Bot WhatsApp
# ================================
# Copiez ce fichier en .env et remplissez vos valeurs
# cp .env.example .env

# Port du serveur web (health check)
PORT=3000

# Clé API Google Gemini (pour la commande IA)
# Obtenez-la sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Numéros des propriétaires du bot (séparés par des virgules, format international sans +)
# Exemple : 33612345678,237699112233
OWNER_NUMBERS=

# Numéros bannis (séparés par des virgules, laisser vide par défaut)
BANNED_NUMBERS=

# Nom du bot (affiché dans les messages)
BOT_NAME=WhatsBot

# Nom du créateur (affiché dans about, help, info)
CREATOR_NAME=Developer

# Liens du créateur (optionnels, pour la commande about)
GITHUB_LINK=https://github.com
LINKEDIN_LINK=

# Préfixe des commandes
PREFIX=.

# Mode illimité (true = pas de limite de commandes, false = limite activée)
UNLIMITED_MODE=true

# Limite de commandes gratuites par utilisateur (si UNLIMITED_MODE=false)
COMMAND_LIMIT=3

# Message de bienvenue du groupe (optionnel, utilisé par la commande add)
# GROUP_WELCOME_MESSAGE=Bienvenue ! Lisez les règles du groupe.

# Prompt système personnalisé pour l'IA (optionnel)
# AI_SYSTEM_PROMPT=Tu es un assistant IA utile et amical.
