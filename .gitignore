# ================================
# .gitignore — WhatsBot
# ================================

# ---------- Dependencies ----------
node_modules/
jspm_packages/
bower_components/
.pnp/
.pnp.js

# ---------- Environment ----------
.env
.env.*
!.env.example

# ---------- WhatsApp Session (CRITICAL — never commit!) ----------
auth_info/
session/
sessions/

# ---------- YouTube Cookies (CRITICAL — never commit!) ----------
yt_cookies.txt
cookies.txt

# ---------- Database ----------
*.db
*.sqlite
*.sqlite3

# ---------- User Data ----------
users.json

# ---------- Temporary Files (media downloads) ----------
temp_*
tmp_*
*.tmp

# ---------- Archives ----------
*.zip
*.tar.gz
*.rar
*.7z

# ---------- Logs ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pids/
*.pid
*.seed
*.pid.lock

# ---------- Build / Output ----------
dist/
build/
out/
.next/
.nuxt/

# ---------- Cache ----------
.cache/
.parcel-cache/
.npm/
.eslintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# ---------- Test / Coverage ----------
coverage/
*.lcov
.nyc_output/

# ---------- OS Files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------- IDE / Editor ----------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ---------- Runtime ----------
.node_repl_history
*.tgz
.yarn-integrity
setup_azure_sp.py
/platform-manager
/platform-portal